<%# Here dom_id(quote) generates unique turbo-frame id: quote_1, quote_2, . . .  %>
<%= turbo_frame_tag dom_id(quote) do %>
  <div class="quote">
    <%= link_to quote.name, quote_path(quote), data: {turbo_frame: "_top"}%>
    <div class="quote__actions">
      <%= button_to "Delete", quote_path(quote), method: :delete, class: 'btn btn--light', data: {turbo_frame: "_top"}%>
      <%= link_to 'Edit', edit_quote_path(quote), class: 'btn btn--light' %>
    </div>
  </div>
<% end %>
